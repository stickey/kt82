{
  "name": "kt82",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.21.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "bcrypt", "esbuild", "prisma"]
  },
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:tracker": "pnpm --filter tracker dev",
    "dev:captain": "pnpm --filter captain dev",
    "dev:manager": "pnpm --filter manager dev",
    "dev:driver": "pnpm --filter driver dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "vercel-build": "bash scripts/vercel-build.sh",
    "db:migrate": "cd server && pnpm exec prisma migrate deploy"
  }
}
